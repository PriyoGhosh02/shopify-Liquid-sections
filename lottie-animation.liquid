{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .json-animation-section-{{ section.id }} {
    --color-background: {{ section.settings.custom_colors_background.red }}, {{ section.settings.custom_colors_background.green }}, {{ section.settings.custom_colors_background.blue }};
    {% if section.settings.custom_image_background != blank %}
      background: url('{{ section.settings.custom_image_background | img_url: 'master' }}') center center / cover no-repeat;
    {% elsif section.settings.custom_gradient_background != blank %}
      background: {{ section.settings.custom_gradient_background }};
    {% else %}
      background-color: {{ section.settings.custom_colors_background }};
    {% endif %}
  }

  {% if section.settings.custom_mobile_image_background != blank %}
    @media screen and (max-width: 749px) {
      .json-animation-section-{{ section.id }} {
        background: url('{{ section.settings.custom_mobile_image_background | img_url: 'master' }}') center center / cover no-repeat;
      }
    }
  {% endif %}

  {% if section.settings.pattern_bg != 'none' %}
    {% assign pattern_color = section.settings.pattern_color %}
    {% assign pattern_size = section.settings.pattern_size %}
    {% assign pattern_thickness = section.settings.pattern_thickness %}
    {% assign pattern_angle = section.settings.pattern_angle %}
    {% if section.settings.pattern_opacity_mode == 'low' %}
      {% assign pattern_opacity = section.settings.pattern_opacity_low | divided_by: 100.0 %}
    {% else %}
      {% assign pattern_opacity = section.settings.pattern_opacity_normal | divided_by: 100.0 %}
    {% endif %}

    .json-animation-section-{{ section.id }} {
      position: relative;
    }
    .json-animation-section-{{ section.id }}::before {
      content: '';
      position: absolute;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      opacity: {{ pattern_opacity }};

      {% if section.settings.pattern_bg == 'dotted' %}
        background-image: radial-gradient(circle, {{ pattern_color }} {{ pattern_thickness }}px, transparent {{ pattern_thickness }}px);
        background-size: {{ pattern_size }}px {{ pattern_size }}px;

      {% elsif section.settings.pattern_bg == 'grid' %}
        background-image:
          linear-gradient({{ pattern_color }} {{ pattern_thickness }}px, transparent {{ pattern_thickness }}px),
          linear-gradient(90deg, {{ pattern_color }} {{ pattern_thickness }}px, transparent {{ pattern_thickness }}px);
        background-size: {{ pattern_size }}px {{ pattern_size }}px;

      {% elsif section.settings.pattern_bg == 'curved-grid' %}
        background-image:
          radial-gradient(ellipse at 0% 50%, transparent 60%, {{ pattern_color }} 60%, {{ pattern_color }} 62%, transparent 62%),
          radial-gradient(ellipse at 100% 50%, transparent 60%, {{ pattern_color }} 60%, {{ pattern_color }} 62%, transparent 62%),
          radial-gradient(ellipse at 50% 0%, transparent 60%, {{ pattern_color }} 60%, {{ pattern_color }} 62%, transparent 62%),
          radial-gradient(ellipse at 50% 100%, transparent 60%, {{ pattern_color }} 60%, {{ pattern_color }} 62%, transparent 62%);
        background-size: {{ pattern_size }}px {{ pattern_size }}px;

      {% elsif section.settings.pattern_bg == 'diagonal-stripes' %}
        background-image: repeating-linear-gradient(
          {{ pattern_angle }}deg,
          {{ pattern_color }},
          {{ pattern_color }} {{ pattern_thickness }}px,
          transparent {{ pattern_thickness }}px,
          transparent {{ pattern_size }}px
        );

      {% elsif section.settings.pattern_bg == 'zigzag' %}
        background-image:
          linear-gradient(135deg, {{ pattern_color }} 25%, transparent 25%) -{{ pattern_size | divided_by: 2 }}px 0,
          linear-gradient(225deg, {{ pattern_color }} 25%, transparent 25%) -{{ pattern_size | divided_by: 2 }}px 0,
          linear-gradient(315deg, {{ pattern_color }} 25%, transparent 25%),
          linear-gradient(45deg, {{ pattern_color }} 25%, transparent 25%);
        background-size: {{ pattern_size }}px {{ pattern_size | divided_by: 2 }}px;

      {% elsif section.settings.pattern_bg == 'arrow-pattern' %}
        background-image:
          linear-gradient(135deg, {{ pattern_color }} 25%, transparent 25%),
          linear-gradient(225deg, {{ pattern_color }} 25%, transparent 25%),
          linear-gradient(45deg, {{ pattern_color }} 25%, transparent 25%),
          linear-gradient(315deg, {{ pattern_color }} 25%, transparent 25%);
        background-size: {{ pattern_size }}px {{ pattern_size }}px;

      {% elsif section.settings.pattern_bg == 'radial-rings' %}
        background-image: radial-gradient(circle, transparent 40%, {{ pattern_color }} 40%, {{ pattern_color }} 45%, transparent 45%);
        background-size: {{ pattern_size }}px {{ pattern_size }}px;

      {% elsif section.settings.pattern_bg == 'diamond-grid-1' %}
        background-image:
          linear-gradient(45deg, {{ pattern_color }} 25%, transparent 25%),
          linear-gradient(-45deg, {{ pattern_color }} 25%, transparent 25%),
          linear-gradient(45deg, transparent 75%, {{ pattern_color }} 75%),
          linear-gradient(-45deg, transparent 75%, {{ pattern_color }} 75%);
        background-size: {{ pattern_size }}px {{ pattern_size }}px;
        background-position: 0 0, 0 {{ pattern_size | divided_by: 2 }}px, {{ pattern_size | divided_by: 2 }}px -{{ pattern_size | divided_by: 2 }}px, -{{ pattern_size | divided_by: 2 }}px 0px;

      {% elsif section.settings.pattern_bg == 'diamond-grid-2' %}
        background-image:
          linear-gradient(45deg, {{ pattern_color }} 12%, transparent 12%, transparent 88%, {{ pattern_color }} 88%),
          linear-gradient(135deg, {{ pattern_color }} 12%, transparent 12%, transparent 88%, {{ pattern_color }} 88%);
        background-size: {{ pattern_size }}px {{ pattern_size }}px;

      {% elsif section.settings.pattern_bg == 'quatrefoils' %}
        background-image:
          radial-gradient(circle at 0% 50%, transparent 28%, {{ pattern_color }} 28%, {{ pattern_color }} 32%, transparent 32%),
          radial-gradient(circle at 100% 50%, transparent 28%, {{ pattern_color }} 28%, {{ pattern_color }} 32%, transparent 32%),
          radial-gradient(circle at 50% 0%, transparent 28%, {{ pattern_color }} 28%, {{ pattern_color }} 32%, transparent 32%),
          radial-gradient(circle at 50% 100%, transparent 28%, {{ pattern_color }} 28%, {{ pattern_color }} 32%, transparent 32%);
        background-size: {{ pattern_size }}px {{ pattern_size }}px;

      {% elsif section.settings.pattern_bg == 'ovals' %}
        background-image: radial-gradient(ellipse 40% 60% at 50% 50%, transparent 60%, {{ pattern_color }} 60%, {{ pattern_color }} 65%, transparent 65%);
        background-size: {{ pattern_size }}px {{ pattern_size }}px;

      {% elsif section.settings.pattern_bg == 'hexagons' %}
        background-image:
          linear-gradient(60deg, {{ pattern_color }} 25%, transparent 25%, transparent 75%, {{ pattern_color }} 75%),
          linear-gradient(120deg, {{ pattern_color }} 25%, transparent 25%, transparent 75%, {{ pattern_color }} 75%);
        background-size: {{ pattern_size }}px {{ pattern_size | times: 1.732 | round }}px;

      {% elsif section.settings.pattern_bg == 'curvy' %}
        background-image:
          radial-gradient(ellipse at top left, {{ pattern_color }} 0%, transparent 50%),
          radial-gradient(ellipse at bottom right, {{ pattern_color }} 0%, transparent 50%);
        background-size: {{ pattern_size }}px {{ pattern_size }}px;
      {% endif %}
    }
    .json-animation-section-{{ section.id }} > * {
      position: relative;
      z-index: 1;
    }
  {% endif %}

  {% if section.settings.desktop_page_width == 'custom' %}
    #PageWidth-{{ section.id }} {
      max-width: {{ section.settings.custom_page_width | divided_by: 10.0 }}rem;
    }
  {% endif %}

  .json-animation__wrapper-{{ section.id }} {
    display: flex;
    flex-direction: column;
  }

  {% if section.settings.desktop_json_width != 'full' %}
    @media screen and (min-width: 750px) {
      .json-animation__wrapper-{{ section.id }} {
        align-items: {{ section.settings.alignment }};
      }
      .json-animation__canvas-{{ section.id }} {
        {% if section.settings.desktop_json_width == 'pixels' %}
          max-width: {{ section.settings.pixels_width_desktop | divided_by: 10.0 }}rem;
          width: 100%;
        {% else %}
          width: {{ section.settings.percentage_width_desktop }}%;
        {% endif %}
      }
    }
  {% endif %}

  {% if section.settings.mobile_width < 100 %}
    @media screen and (max-width: 749px) {
      .json-animation__wrapper-{{ section.id }} {
        align-items: {{ section.settings.mobile_alignment }};
      }
      .json-animation__canvas-{{ section.id }} {
        width: {{ section.settings.mobile_width }}%;
      }
    }
  {% endif %}

  .json-animation__placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 40px;
    border: 2px dashed #ccc;
    border-radius: 8px;
    width: 100%;
  }

  .json-animation__placeholder p {
    margin: 4px 0;
    color: #666;
  }

  {% if section.settings.visibility == 'desktop-hidden' %}
    @media screen and (min-width: 750px) {
      .json-animation-section-{{ section.id }} { display: none !important; }
    }
  {% elsif section.settings.visibility == 'mobile-hidden' %}
    @media screen and (max-width: 749px) {
      .json-animation-section-{{ section.id }} { display: none !important; }
    }
  {% endif %}
{%- endstyle -%}

{% if section.settings.display_id %}
  <div style="text-align:center; font-size:12px; padding:4px; background:#f0f0f0; color:#333;">
    Section ID: <strong>{{ section.id }}</strong>
  </div>
{% endif %}

<div
  id="PageWidth-{{ section.id }}"
  class="
    json-animation-section-{{ section.id }}
    {% if section.settings.desktop_page_width == 'desktop-full-page' %} desktop-full-page{% endif %}
    {% if section.settings.desktop_page_width == 'desktop-full-page-no-padding' %} desktop-full-page-no-padding{% endif %}
  "
>
  <div
    class="
      json-animation__wrapper-{{ section.id }}
      section-{{ section.id }}-padding
      {% if section.settings.desktop_page_width == 'page-width--narrow' %} page-width--narrow{% endif %}
      {% if section.settings.desktop_page_width == 'normal' %} page-width{% endif %}
      {% if section.settings.desktop_page_width == 'custom' %} page-width{% endif %}
      {% if section.settings.mobile_full_page %} mobile-full-page{% endif %}
    "
    {% if section.settings.desktop_page_width != 'desktop-full-page' and section.settings.desktop_page_width != 'desktop-full-page-no-padding' %}
      style="margin-left: auto; margin-right: auto;"
    {% endif %}
  >
    {% if section.settings.animation_json_url != blank %}
      <json-animation
        class="json-animation__canvas json-animation__canvas-{{ section.id }}"
        animation-url="{{ section.settings.animation_json_url }}"
        animation-url-mobile="{{ section.settings.animation_json_url_mobile }}"
        loop="{{ section.settings.loop }}"
        autoplay="{{ section.settings.autoplay }}"
        speed="{{ section.settings.animation_speed | divided_by: 100.0 }}"
        {% if section.settings.click_to_play %}click-to-play="true"{% endif %}
      >
        {% if section.settings.fallback_image != blank %}
          <img
            src="{{ section.settings.fallback_image | image_url: width: 1200 }}"
            alt="{{ section.settings.fallback_image.alt | escape }}"
            loading="lazy"
            width="{{ section.settings.fallback_image.width }}"
            height="{{ section.settings.fallback_image.height }}"
          >
        {% endif %}
      </json-animation>
    {% else %}
      <div class="json-animation__placeholder">
        <p>Add your animation file URL</p>
        <p>Detailed instructions are provided in section settings</p>
      </div>
    {% endif %}
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/lottie-web/5.12.2/lottie.min.js"></script>

<script>
(function() {
  class JsonAnimation extends HTMLElement {
    connectedCallback() {
      this._init();
      window.addEventListener('resize', this._onResize.bind(this));
    }

    disconnectedCallback() {
      window.removeEventListener('resize', this._onResize.bind(this));
      if (this._animation) this._animation.destroy();
    }

    _getUrl() {
      const mobileUrl = this.getAttribute('animation-url-mobile');
      const desktopUrl = this.getAttribute('animation-url');
      return (window.innerWidth < 750 && mobileUrl) ? mobileUrl : desktopUrl;
    }

    _init() {
      const url = this._getUrl();
      if (!url) return;
      if (this._currentUrl === url) return;
      this._currentUrl = url;

      if (this._animation) {
        this._animation.destroy();
        this._animation = null;
      }

      // Clear fallback image
      this.innerHTML = '';

      const loop = this.getAttribute('loop') === 'true';
      const autoplay = this.getAttribute('autoplay') === 'true';
      const speed = parseFloat(this.getAttribute('speed')) || 1;
      const clickToPlay = this.getAttribute('click-to-play') === 'true';

      this._animation = lottie.loadAnimation({
        container: this,
        renderer: 'svg',
        loop: loop,
        autoplay: autoplay,
        path: url
      });

      this._animation.setSpeed(speed);

      if (!autoplay) {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              this._animation.play();
              if (!loop) observer.unobserve(this);
            } else if (loop) {
              this._animation.pause();
            }
          });
        }, { threshold: 0.3 });

        observer.observe(this);
      }

      if (clickToPlay) {
        this.style.cursor = 'pointer';
        this.addEventListener('click', () => {
          if (this._animation.isPaused) {
            this._animation.play();
          } else {
            this._animation.pause();
          }
        });
      }
    }

    _onResize() {
      clearTimeout(this._resizeTimer);
      this._resizeTimer = setTimeout(() => this._init(), 250);
    }
  }

  if (!customElements.get('json-animation')) {
    customElements.define('json-animation', JsonAnimation);
  }
})();
</script>

{% schema %}
{
  "name": "JSON (Lottie) Animation",
  "tag": "section",
  "class": "section section-json-animation",
  "settings": [
    {
      "type": "checkbox",
      "id": "display_id",
      "label": "Display section ID",
      "info": "ID is used in the Sections group section to merge 2 sections. ID can also be put inside any button link and the button will scroll to this section.",
      "default": false
    },
    {
      "type": "select",
      "id": "visibility",
      "options": [
        {
          "value": "desktop-hidden",
          "label": "Mobile only"
        },
        {
          "value": "mobile-hidden",
          "label": "Desktop only"
        },
        {
          "value": "always-display",
          "label": "All devices"
        }
      ],
      "label": "Display on",
      "default": "always-display"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "color",
      "id": "custom_colors_background",
      "default": "#FFFFFF",
      "label": "Background color"
    },
    {
      "type": "color_background",
      "id": "custom_gradient_background",
      "label": "Gradient background",
      "info": "If added, replaces background color."
    },
    {
      "type": "image_picker",
      "id": "custom_image_background",
      "label": "Image background",
      "info": "If added, replaces gradient and background color."
    },
    {
      "type": "image_picker",
      "id": "custom_mobile_image_background",
      "label": "Mobile image background",
      "info": "If empty, the desktop image background will also be applied to mobile."
    },
    {
      "type": "select",
      "id": "pattern_bg",
      "label": "Background pattern",
      "default": "none",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "dotted", "label": "Dots" },
        { "value": "grid", "label": "Grid" },
        { "value": "curved-grid", "label": "Curved grid" },
        { "value": "diagonal-stripes", "label": "Stripes" },
        { "value": "zigzag", "label": "ZigZag" },
        { "value": "arrow-pattern", "label": "3D Boxes" },
        { "value": "radial-rings", "label": "Rings" },
        { "value": "diamond-grid-1", "label": "Diamond grid 1" },
        { "value": "diamond-grid-2", "label": "Diamond grid 2" },
        { "value": "quatrefoils", "label": "Quatrefoils" },
        { "value": "ovals", "label": "Ovals" },
        { "value": "hexagons", "label": "Hexagons" },
        { "value": "curvy", "label": "Curvy" }
      ]
    },
    {
      "type": "color",
      "id": "pattern_color",
      "label": "Pattern color",
      "default": "#6D388B",
      "visible_if": "{{ section.settings.pattern_bg != 'none' }}"
    },
    {
      "type": "range",
      "id": "pattern_size",
      "min": 4,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Pattern size / spacing",
      "default": 20,
      "visible_if": "{{ section.settings.pattern_bg != 'none' }}"
    },
    {
      "type": "range",
      "id": "pattern_thickness",
      "min": 1,
      "max": 10,
      "step": 1,
      "unit": "px",
      "label": "Line / dot thickness",
      "default": 2,
      "visible_if": "{{ section.settings.pattern_bg == 'dotted' or section.settings.pattern_bg == 'grid' or section.settings.pattern_bg == 'diagonal-stripes' or section.settings.pattern_bg == 'radial-rings' }}"
    },
    {
      "type": "range",
      "id": "pattern_angle",
      "min": 0,
      "max": 180,
      "step": 15,
      "unit": "deg",
      "label": "Stripe angle",
      "default": 45,
      "visible_if": "{{ section.settings.pattern_bg == 'diagonal-stripes' }}"
    },
    {
      "type": "select",
      "id": "pattern_opacity_mode",
      "label": "Opacity type",
      "default": "low",
      "options": [
        { "value": "low", "label": "Low" },
        { "value": "normal", "label": "Normal" }
      ],
      "visible_if": "{{ section.settings.pattern_bg != 'none' }}"
    },
    {
      "type": "range",
      "id": "pattern_opacity_low",
      "min": 1,
      "max": 20,
      "step": 1,
      "unit": "%",
      "label": "Opacity",
      "default": 7,
      "visible_if": "{{ section.settings.pattern_bg != 'none' and section.settings.pattern_opacity_mode == 'low' }}"
    },
    {
      "type": "range",
      "id": "pattern_opacity_normal",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Opacity",
      "default": 80,
      "visible_if": "{{ section.settings.pattern_bg != 'none' and section.settings.pattern_opacity_mode == 'normal' }}"
    },
    {
      "type": "header",
      "content": "HOW TO USE?"
    },
    {
      "type": "paragraph",
      "content": "1) Find and configure your animation on [LottieFiles](https://lottiefiles.com/)"
    },
    {
      "type": "paragraph",
      "content": "2) Download your animation in .json format (NOT in .lottie format)"
    },
    {
      "type": "paragraph",
      "content": "3) Go to Shopify admin > Content > Files and upload the .json file you downloaded"
    },
    {
      "type": "paragraph",
      "content": "4) From there, copy the URL of the file"
    },
    {
      "type": "paragraph",
      "content": "5) In the theme editor, paste the copied URL into the 'Animation file URL' setting below"
    },
    {
      "type": "paragraph",
      "content": "6) OPTIONAL: If you want a separate animation for mobile, repeat the same steps and paste the 2nd file URL into the 'Mobile animation file URL' setting"
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "text",
      "id": "animation_json_url",
      "label": "Animation file URL"
    },
    {
      "type": "text",
      "id": "animation_json_url_mobile",
      "label": "Mobile animation file URL",
      "info": "OPTIONAL: Use a different animation for mobile. If left blank, desktop animation will be used."
    },
    {
      "type": "image_picker",
      "id": "fallback_image",
      "label": "Fallback image",
      "info": "Shown while the animation loads, or if the animation fails to load."
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop animation",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": true,
      "info": "If disabled, animation plays when scrolled into view."
    },
    {
      "type": "checkbox",
      "id": "click_to_play",
      "label": "Click to play/pause",
      "default": false
    },
    {
      "type": "range",
      "id": "animation_speed",
      "min": 10,
      "max": 300,
      "step": 10,
      "unit": "%",
      "label": "Animation speed",
      "default": 100
    },
    {
      "type": "header",
      "content": "Desktop layout"
    },
    {
      "type": "select",
      "id": "desktop_page_width",
      "options": [
        {
          "value": "page-width--narrow",
          "label": "Narrow"
        },
        {
          "value": "normal",
          "label": "Normal"
        },
        {
          "value": "desktop-full-page",
          "label": "Full width"
        },
        {
          "value": "desktop-full-page-no-padding",
          "label": "Full width without side spacing"
        },
        {
          "value": "custom",
          "label": "Custom"
        }
      ],
      "default": "normal",
      "label": "Page width"
    },
    {
      "type": "number",
      "id": "custom_page_width",
      "label": "Custom page width (px)",
      "default": 900,
      "visible_if": "{{ section.settings.desktop_page_width == 'custom' }}"
    },
    {
      "type": "select",
      "id": "desktop_json_width",
      "label": "Animation width",
      "options": [
        {
          "value": "full",
          "label": "Full"
        },
        {
          "value": "pixels",
          "label": "Fixed width in pixels"
        },
        {
          "value": "percentage",
          "label": "Width in percentage"
        }
      ],
      "default": "pixels"
    },
    {
      "type": "range",
      "id": "pixels_width_desktop",
      "min": 300,
      "max": 1600,
      "step": 100,
      "unit": "px",
      "label": "Animation width",
      "default": 500,
      "visible_if": "{{ section.settings.desktop_json_width == 'pixels' }}"
    },
    {
      "type": "range",
      "id": "percentage_width_desktop",
      "min": 10,
      "max": 95,
      "step": 5,
      "unit": "%",
      "label": "Animation width",
      "default": 40,
      "visible_if": "{{ section.settings.desktop_json_width == 'percentage' }}"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Right"
        }
      ],
      "default": "center",
      "visible_if": "{{ section.settings.desktop_json_width != 'full' }}"
    },
    {
      "type": "header",
      "content": "Mobile layout"
    },
    {
      "type": "checkbox",
      "id": "mobile_full_page",
      "label": "Full page width",
      "default": false
    },
    {
      "type": "range",
      "id": "mobile_width",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Animation width",
      "default": 100
    },
    {
      "type": "select",
      "id": "mobile_alignment",
      "label": "Alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Right"
        }
      ],
      "default": "center",
      "visible_if": "{{ section.settings.mobile_width < 100 }}"
    },
    {
      "type": "header",
